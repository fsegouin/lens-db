# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Secret salt for hashing IP addresses (used for per-IP rate limiting on ratings)
# Generate with: openssl rand -hex 32
RATE_HASH_SALT=""

# Upstash Redis (for rate limiting across serverless instances)
# Create a free database at https://console.upstash.com or via Vercel integration
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# Admin portal password
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=""

# Secret for signing session tokens (REQUIRED - app will not start without it)
# Generate with: openssl rand -base64 32
SESSION_SECRET=""

# Resend (email service for verification emails)
# Create account at https://resend.com and verify your domain
RESEND_API_KEY=""
RESEND_FROM_EMAIL="The Lens DB <noreply@thelensdb.com>"

# Base URL for email links (verification, etc.)
APP_URL="https://thelensdb.com"
