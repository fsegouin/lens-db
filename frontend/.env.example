# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Secret salt for hashing IP addresses (used for per-IP rate limiting on ratings)
# Generate with: openssl rand -hex 32
RATE_HASH_SALT=""

# Upstash Redis (for rate limiting across serverless instances)
# Create a free database at https://console.upstash.com or via Vercel integration
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# Admin portal password
# Generate with: openssl rand -base64 32
ADMIN_PASSWORD=""

# Separate secret for signing session tokens (recommended)
# If not set, falls back to ADMIN_PASSWORD
# Generate with: openssl rand -base64 32
SESSION_SECRET=""
